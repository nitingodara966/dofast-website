# DoFast environment variables — copy to .env.local and fill in values.
# Never commit real values. All variables below are server-side only;
# nothing here may be renamed to NEXT_PUBLIC_*.

# Waitlist email delivery via EmailJS (Account -> API Keys for the keys;
# Email Services / Email Templates for the IDs).
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Better Auth: secret for signing sessions (generate with `openssl rand -base64 32`)
# and the canonical app URL (http://localhost:3000 locally, production URL on Vercel).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# GitHub App (github.com/settings/apps -> your app). PRIVATE_KEY is the
# base64-encoded .pem: `base64 -i <file>.pem | tr -d '\n'`.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# Supabase Postgres connection string (Dashboard -> Connect -> Transaction
# pooler URI, port 6543). Used by the app at runtime and by
# `npm run db:migrate` to apply migrations.
DATABASE_URL=
